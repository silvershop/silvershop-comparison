{
    "name": "silvershop/comparison",
    "description": "Submodule for SilverShop which allows you to compare products in a table.",
    "type": "silverstripe-vendormodule",
    "keywords": ["silverstripe", "ecommerce", "shop", "silvershop", "comparison", "compare", "products"],
    "require" : {
        "php": "^8.1",
        "silvershop/core": "dev-main",
        "php-http/guzzle7-adapter": "1.x-dev"
    },
    "authors": [{
      "name": "SilverShop Contributors",
      "homepage": "https://github.com/silvershop/silvershop-Comparison/graphs/contributors"
    }],
    "require-dev": {
        "phpunit/phpunit": "^11",
        "cambis/silverstan": "^2.1",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --no-progress --memory-limit=1G",
        "test": "./vendor/bin/phpunit",
        "coverage": "./vendor/bin/phpunit --coverage-html coverage"
    },
    "prefer-stable": false,
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-main": "6.x-dev"
        },
        "expose": [
            "javascript",
            "images"
        ]
    },
    "autoload": {
        "psr-4": {
            "SilverShop\\Comparison\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SilverShop\\Comparison\\Tests\\": "tests/unit/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    }
}
